{
  "manifest_version": 3,
  "name": "Job Tracker",
  "version": "1.2",
  "description": "LinkedIn-only job tracker — auto-appends to a single persistent tracker",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "icons": {
    "128": "icon128.png"
  }
}
